"""
Модели данных для АИС Burger King
Содержит классы для представления сущностей системы
"""

from dataclasses import dataclass
from typing import List, Dict
from datetime import datetime

@dataclass
class MenuItem:
    """Модель продукта из меню"""
    id: int
    name: str
    price: float
    
    def __str__(self):
        return f"{self.id}. {self.name} - {self.price:.2f} ₽"

@dataclass
class CartItem:
    """Модель товара в корзине"""
    product_id: int
    name: str
    price: float
    quantity: int
    
    @property
    def total(self) -> float:
        """Общая стоимость позиции"""
        return self.price * self.quantity

@dataclass
class Order:
    """Модель заказа"""
    id: int
    user_id: int
    total_price: float
    status: str
    created_at: datetime
    
@dataclass
class User:
    """Модель пользователя"""
    id: int
    username: str
    password: str


