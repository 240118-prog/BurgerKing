"""
Главный модуль АИС Burger King - CLI интерфейс
"""

from database import AISService
from models import MenuItem, CartItem
from typing import Dict

class BurgerKingCLI:
    """Консольный интерфейс для работы с АИС"""
    
    def __init__(self):
        self.service = AISService()
        self.cart: Dict[int, int] = {}
    
    def clear_screen(self):
        """Очистка экрана"""
        print("\n" * 2)
    
    def show_header(self, title: str):
        """Отображение заголовка"""
        print("=" * 50)
        print(f"🍔 BURGER KING АИС - {title}")
        print("=" * 50)
    
    def show_menu(self):
        """Отображение доступных бургеров"""
        self.show_header("НАШЕ МЕНЮ")
        items = self.service.get_menu()
        
        if not items:
            print("⚠️ Меню временно недоступно")
            return
        
        print(f"{'ID':<4} {'Название':<25} {'Цена':<10}")
        print("-" * 40)
        for item in items:
            print(f"{item.id:<4} {item.name:<25} {item.price:.2f} ₽")
        print("-" * 40)
    
    def show_cart(self):
        """Отображение содержимого корзины"""
        self.show_header("КОРЗИНА")
        
        if not self.cart:
            print("🛒 Корзина пуста")
            return
        
        total = 0
        print(f"{'Товар':<25} {'Кол-во':<8} {'Цена':<10} {'Сумма':<10}")
        print("-" * 55)
        
        for product_id, quantity in self.cart.items():
            item = self.service.menu_repo.get_item_by_id(product_id)
            if item:
                subtotal = item.price * quantity
                total += subtotal
                print(f"{item.name:<25} {quantity:<8} {item.price:.2f} ₽   {subtotal:.2f} ₽")
        
        print("-" * 55)
        print(f"ИТОГО: {total:.2f} ₽")
    
    def add_to_cart(self):
        """Добавление товара в корзину"""
        self.show_menu()
        
        try:
            product_id = int(input("\n🔢 Введите ID товара: "))
            quantity = int(input("🔢 Введите количество: "))
            
            if quantity <= 0:
                print("❌ Количество должно быть положительным")
                return
            
            item = self.service.menu_repo.get_item_by_id(product_id)
            if not item:
                print("❌ Товар не найден")
                return
            
            if product_id in self.cart:
                self.cart[product_id] += quantity
            else:
                self.cart[product_id] = quantity
            
            print(f"✅ {quantity}x {item.name} добавлен(ы) в корзину")
            
        except ValueError:
            print("❌ Ошибка: введите корректное число")
    
    def checkout(self):
        """Оформление заказа и имитация оплаты"""
        self.show_cart()
        
        if not self.cart:
            print("\n❌ Нельзя оформить пустой заказ")
            return
        
        print("\n📋 Оформление заказа...")
        
        try:
            order_id = self.service.create_order(self.cart)
            print(f"✅ Заказ #{order_id} создан в системе")
            
            print("🏦 Запрос к платежному шлюзу...")
            if self.service.confirm_payment(order_id):
                print("✅ Оплата подтверждена банком")
                print(f"🎉 Заказ #{order_id} успешно оформлен и оплачен!")
                self.cart.clear()
            else:
                print("❌ Ошибка оплаты")
                
        except ValueError as e:
            print(f"❌ Ошибка: {e}")
        except Exception as e:
            print(f"❌ Непредвиденная ошибка: {e}")
    
    def show_order_history(self):
        """Просмотр истории заказов"""
        self.show_header("ИСТОРИЯ ЗАКАЗОВ")
        
        orders = self.service.get_order_history()
        
        if not orders:
            print("📭 У вас пока нет заказов")
            return
        
        for order in orders:
            status_icon = "✅" if order.status == "Оплачено" else "🕐"
            print(f"{status_icon} Заказ #{order.id} | {order.total_price:.2f} ₽ | {order.status} | {order.created_at}")
    
    def run(self):
        """Главный цикл приложения"""
        self.clear_screen()
        self.show_header("АВТОРИЗАЦИЯ")
        
        login_attempts = 0
        while login_attempts < 3:
            username = input("👤 Логин: ")
            password = input("🔐 Пароль: ")
            
            if self.service.login(username, password):
                print(f"\n✅ Добро пожаловать, {username}!")
                break
            else:
                login_attempts += 1
                print(f"❌ Неверный логин или пароль. Осталось попыток: {3 - login_attempts}")
        
        if not self.service.current_user:
            print("❌ Превышено количество попыток входа. Доступ закрыт.")
            return
        
        while True:
            self.clear_screen()
            self.show_header("ГЛАВНОЕ МЕНЮ")
            print("\n1️⃣  Показать меню")
            print("2️⃣  Добавить в корзину")
            print("3️⃣  Посмотреть корзину")
            print("4️⃣  Оформить заказ")
            print("5️⃣  История заказов")
            print("0️⃣  Выход")
            
            choice = input("\n🔢 Выберите действие: ")
            
            if choice == "1":
                self.clear_screen()
                self.show_menu()
                input("\nНажмите Enter для продолжения...")
            
            elif choice == "2":
                self.clear_screen()
                self.add_to_cart()
                input("\nНажмите Enter для продолжения...")
            
            elif choice == "3":
                self.clear_screen()
                self.show_cart()
                input("\nНажмите Enter для продолжения...")
            
            elif choice == "4":
                self.clear_screen()
                self.checkout()
                input("\nНажмите Enter для продолжения...")
            
            elif choice == "5":
                self.clear_screen()
                self.show_order_history()
                input("\nНажмите Enter для продолжения...")
            
            elif choice == "0":
                print("\n👋 Спасибо за использование АИС Burger King! До свидания!")
                break
            
            else:
                print("❌ Неверный выбор")
                input("Нажмите Enter для продолжения...")

if __name__ == "__main__":
    app = BurgerKingCLI()
    app.run()


