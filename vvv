"""
Модуль работы с базой данных и бизнес-логики
Реализует паттерн Repository для доступа к данным
"""

import sqlite3
from typing import List, Optional, Dict
from contextlib import contextmanager
from models import MenuItem, CartItem, Order, User

class DatabaseManager:
    """Менеджер подключения к БД с автоматическим закрытием соединения"""
    
    def __init__(self, db_path: str = "burgerking.db"):
        self.db_path = db_path
    
    @contextmanager
    def get_connection(self):
        """Контекстный менеджер для работы с БД"""
        conn = sqlite3.connect(self.db_path)
        conn.row_factory = sqlite3.Row
        try:
            yield conn
            conn.commit()
        except Exception as e:
            conn.rollback()
            raise e
        finally:
            conn.close()

class MenuRepository:
    """Репозиторий для работы с меню"""
    
    def __init__(self, db_manager: DatabaseManager):
        self.db = db_manager
    
    def get_all_items(self) -> List[MenuItem]:
        """Получение всего меню"""
        with self.db.get_connection() as conn:
            cursor = conn.execute("SELECT id, name, price FROM menu ORDER BY id")
            return [MenuItem(row['id'], row['name'], row['price']) for row in cursor.fetchall()]
    
    def get_item_by_id(self, item_id: int) -> Optional[MenuItem]:
        """Получение продукта по ID"""
        with self.db.get_connection() as conn:
            cursor = conn.execute("SELECT id, name, price FROM menu WHERE id = ?", (item_id,))
            row = cursor.fetchone()
            if row:
                return MenuItem(row['id'], row['name'], row['price'])
            return None

class OrderRepository:
    """Репозиторий для работы с заказами"""
    
    def __init__(self, db_manager: DatabaseManager):
        self.db = db_manager
    
    def create_order(self, user_id: int, items: List[CartItem]) -> int:
        """Создание нового заказа и его деталей в транзакции"""
        total_price = sum(item.total for item in items)
        
        with self.db.get_connection() as conn:
            cursor = conn.execute(
                "INSERT INTO orders (user_id, total_price, status) VALUES (?, ?, ?)",
                (user_id, total_price, "Создан")
            )
            order_id = cursor.lastrowid
            
            for item in items:
                conn.execute(
                    "INSERT INTO order_details (order_id, product_id, quantity) VALUES (?, ?, ?)",
                    (order_id, item.product_id, item.quantity)
                )
            
            return order_id
    
    def update_order_status(self, order_id: int, status: str) -> None:
        """Обновление статуса заказа"""
        with self.db.get_connection() as conn:
            conn.execute(
                "UPDATE orders SET status = ? WHERE id = ?",
                (status, order_id)
            )
    
    def get_user_orders(self, user_id: int) -> List[Order]:
        """Получение истории заказов пользователя"""
        with self.db.get_connection() as conn:
            cursor = conn.execute(
                "SELECT id, user_id, total_price, status, created_at FROM orders WHERE user_id = ? ORDER BY created_at DESC",
                (user_id,)
            )
            return [Order(row['id'], row['user_id'], row['total_price'], 
                         row['status'], row['created_at']) for row in cursor.fetchall()]

class UserRepository:
    """Репозиторий для работы с пользователями"""
    
    def __init__(self, db_manager: DatabaseManager):
        self.db = db_manager
    
    def authenticate(self, username: str, password: str) -> Optional[User]:
        """Проверка учетных данных пользователя"""
        with self.db.get_connection() as conn:
            cursor = conn.execute(
                "SELECT id, username, password FROM users WHERE username = ? AND password = ?",
                (username, password)
            )
            row = cursor.fetchone()
            if row:
                return User(row['id'], row['username'], row['password'])
            return None

class AISService:
    """Основной сервис АИС - координация работы репозиториев"""
    
    def __init__(self):
        self.db_manager = DatabaseManager()
        self.menu_repo = MenuRepository(self.db_manager)
        self.order_repo = OrderRepository(self.db_manager)
        self.user_repo = UserRepository(self.db_manager)
        self.current_user: Optional[User] = None
    
    def login(self, username: str, password: str) -> bool:
        """Аутентификация пользователя"""
        user = self.user_repo.authenticate(username, password)
        if user:
            self.current_user = user
            return True
        return False
    
    def get_menu(self) -> List[MenuItem]:
        """Получение текущего меню"""
        return self.menu_repo.get_all_items()
    
    def create_order(self, cart: Dict[int, int]) -> int:
        """Создание заказа из корзины"""
        if not self.current_user:
            raise ValueError("Пользователь не авторизован")
        
        cart_items = []
        for product_id, quantity in cart.items():
            item = self.menu_repo.get_item_by_id(product_id)
            if item:
                cart_items.append(CartItem(item.id, item.name, item.price, quantity))
            else:
                raise ValueError(f"Товар с ID {product_id} не найден")
        
        if not cart_items:
            raise ValueError("Корзина пуста")
        
        order_id = self.order_repo.create_order(self.current_user.id, cart_items)
        return order_id
    
    def confirm_payment(self, order_id: int) -> bool:
        """Имитация подтверждения оплаты банком"""
        print(f"💰 Имитация платежа для заказа #{order_id}...")
        self.order_repo.update_order_status(order_id, "Оплачено")
        return True
    
    def get_order_history(self) -> List[Order]:
        """История заказов текущего пользователя"""
        if not self.current_user:
            return []
        return self.order_repo.get_user_orders(self.current_user.id)


